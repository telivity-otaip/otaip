# OTAIP environment variables
# Copy this file to .env and fill in your values

# Duffel NDC API key (get from app.duffel.com -> Developers -> Access Tokens)
# Use duffel_test_... for sandbox, duffel_live_... for production
DUFFEL_API_KEY=duffel_test_your_key_here

# Anthropic API key (required for demo/)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Sabre GDS credentials (for packages/connect Sabre adapter)
SABRE_CLIENT_ID=your_client_id
SABRE_CLIENT_SECRET=your_secret
SABRE_ENVIRONMENT=cert

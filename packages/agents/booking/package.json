  "description": "OTAIP Stage 3 agents — GDS/NDC routing, PNR building, validation, queue management",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"

  "description": "OTAIP Stage 2 agents — fare rules, fare construction, and tax calculation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }

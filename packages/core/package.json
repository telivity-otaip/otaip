{
  "name": "@otaip/core",
  "version": "0.2.0",
  "description": "OTAIP core runtime — base agent interfaces and shared types",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {

{
  "name": "@otaip/connect",
  "version": "0.1.0",
  "description": "OTAIP Connect — universal supplier adapter framework for travel booking APIs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@otaip/core": "workspace:*"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  }
}

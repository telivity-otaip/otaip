{
  "name": "@otaip/connect",
  "version": "0.6.0",
  "description": "OTAIP Connect — universal supplier adapter framework for travel booking APIs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "amadeus": "^11.0.0",
    "decimal.js": "^10.6.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@otaip/core": "workspace:*"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.14.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/telivity-otaip/otaip.git",
    "directory": "packages/connect"
  }
}
